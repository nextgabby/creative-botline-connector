# ── Slack ──────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...          # only needed for Socket Mode
SLACK_SIGNING_SECRET=...          # only needed for HTTP mode

# ── Bot identity ──────────────────────────────────
BOT_USER_ID=U07XXXXXXXX          # the bot's own Slack user ID (for @mention detection)

# ── Channel ───────────────────────────────────────
HOTLINE_CHANNEL_ID=C07XXXXXXXX   # #x-creative-botline channel ID

# ── Grok (x.ai) ──────────────────────────────────
XAI_API_KEY=xai-...

# ── Mode ──────────────────────────────────────────
SLACK_SOCKET_MODE=true            # set "false" for HTTP mode on Render

# ── HTTP port (only used when SLACK_SOCKET_MODE=false)
PORT=3000
